# Example values for the Windsurf Context subagent-compatible tool path.
# Copy the keys you need into ~/.config/swegrep/.env (macOS/Linux)
# or ~/.swegrep/.env (Windows).

WINDSURF_API_KEY=sk-ws-01-...
# API_KEY is accepted as an alias for WINDSURF_API_KEY in this config file.
# API_KEY=sk-ws-01-...
WS_APP_VER=1.48.2
WS_LS_VER=1.9544.35
SWEGREP_PATH_FILTER=1
SCOPE_SNAPSHOT_TREE_DEPTH=4
FC_MAX_COMMANDS=8
FC_RESULT_MAX_LINES=80
FC_READFILE_MAX_LINES=200
FC_LINE_MAX_CHARS=300
FC_MAX_TURNS=3
FC_TIMEOUT_MS=30000
